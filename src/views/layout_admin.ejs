<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%- title || 'Praeto Admin' %></title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#1F3864;--navy-d:#162952;--gold:#C9A84C;--gold-l:#E8C96A;
  --ink:#111827;--muted:#6B7280;--border:#E5E0D5;--surface:#F9F8F5;--white:#fff;
  --red:#EF4444;--green:#22C55E;--sidebar:220px}
body{font-family:'Inter',sans-serif;background:var(--surface);color:var(--ink);
  display:flex;min-height:100vh;font-size:14px;-webkit-font-smoothing:antialiased}
.sidebar{width:var(--sidebar);background:#111827;flex-shrink:0;display:flex;flex-direction:column;
  position:fixed;top:0;bottom:0;left:0;z-index:50}
.sidebar-logo{padding:20px;border-bottom:1px solid rgba(255,255,255,0.06)}
.logo-mark{width:32px;height:32px;background:var(--gold);border-radius:2px;
  display:inline-flex;align-items:center;justify-content:center;vertical-align:middle;margin-right:8px}
.logo-mark span{font-family:'Playfair Display',serif;color:var(--navy);font-size:14px;font-weight:900}
.logo-text{display:inline-block;vertical-align:middle}
.logo-name{font-family:'Playfair Display',serif;font-size:13px;color:white;font-weight:700;line-height:1.2;display:block}
.logo-sub{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--gold);letter-spacing:0.15em;
  text-transform:uppercase;margin-top:2px}
.admin-badge{display:inline-block;background:var(--gold);color:var(--navy);font-family:'JetBrains Mono',monospace;
  font-size:8px;font-weight:700;padding:2px 6px;border-radius:2px;letter-spacing:0.08em;margin-top:6px}
.sidebar-nav{flex:1;padding:12px 0;overflow-y:auto}
.nav-section{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,0.25);
  letter-spacing:0.15em;text-transform:uppercase;padding:10px 16px 4px}
.nav-link{display:flex;align-items:center;gap:10px;padding:8px 16px;font-size:13px;font-weight:500;
  color:rgba(255,255,255,0.5);text-decoration:none;transition:all 0.15s}
.nav-link:hover{color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.04)}
.nav-link.active{color:var(--gold);background:rgba(201,168,76,0.08)}
.sidebar-footer{padding:12px 16px;border-top:1px solid rgba(255,255,255,0.06)}
.sidebar-user{font-size:12px;color:rgba(255,255,255,0.5);padding:8px 0}
.sidebar-logout{display:block;width:100%;margin-top:6px;padding:9px 12px;border-radius:3px;
  text-align:center;font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.02em;
  color:var(--gold);text-decoration:none;cursor:pointer;background:rgba(201,168,76,0.12);
  border:1px solid rgba(201,168,76,0.55);transition:all 0.15s}
.sidebar-logout:hover{background:var(--gold);color:var(--navy);border-color:var(--gold)}
.main{margin-left:var(--sidebar);flex:1;display:flex;flex-direction:column}
.topbar{background:white;border-bottom:1px solid var(--border);padding:0 28px;height:56px;
  display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40}
.topbar-title{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--navy)}
.content{flex:1;padding:28px}
.card{background:white;border:1px solid var(--border);border-radius:4px}
.card-header{padding:16px 20px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between}
.card-title{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;color:var(--navy)}
.card-body{padding:20px}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:24px}
.stat-card{background:white;border:1px solid var(--border);border-radius:4px;padding:16px 20px}
.stat-label{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.stat-value{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;color:var(--navy);line-height:1}
.stat-sub{font-size:11px;color:var(--muted);margin-top:3px}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:3px;
  font-size:12px;font-weight:600;text-decoration:none;cursor:pointer;border:1px solid transparent;
  font-family:'Inter',sans-serif;transition:all 0.15s}
.btn-primary{background:var(--gold);color:var(--navy);border-color:var(--gold)}
.btn-primary:hover{background:var(--gold-l)}
.btn-navy{background:var(--navy);color:white}
.btn-navy:hover{background:var(--navy-d)}
.btn-outline{background:transparent;border-color:var(--border);color:var(--ink)}
.btn-outline:hover{border-color:var(--navy);color:var(--navy)}
.btn-danger{background:#FEE2E2;color:#DC2626;border-color:#FECACA}
.btn-danger:hover{background:#FECACA}
.btn-sm{padding:5px 10px;font-size:11px}
.badge{display:inline-block;padding:2px 7px;border-radius:2px;font-size:10px;font-weight:700;
  font-family:'JetBrains Mono',monospace;letter-spacing:0.06em;text-transform:uppercase}
.badge-foundation{background:#EFF4FF;color:var(--navy)}
.badge-practitioner{background:#F0FDF4;color:#166534}
.badge-elite{background:#FEF3C7;color:#92400E}
.badge-active{background:#DCFCE7;color:#166534}
.badge-pending{background:#FEF3C7;color:#92400E}
.badge-suspended{background:#FEE2E2;color:#DC2626}
.badge-cancelled{background:#F3F4F6;color:#6B7280}
.badge-critical{background:#FEE2E2;color:#DC2626}
.badge-warning{background:#FEF3C7;color:#92400E}
.badge-info{background:#DBEAFE;color:#1E40AF}
.table-wrap{overflow-x:auto}
table.data-table{width:100%;border-collapse:collapse}
.data-table th{background:var(--surface);font-family:'JetBrains Mono',monospace;font-size:9px;
  font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);
  padding:8px 14px;text-align:left;border-bottom:2px solid var(--border)}
.data-table td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:12px;color:var(--ink)}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:var(--surface)}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:11px;font-weight:600;color:var(--ink);margin-bottom:4px}
.form-input,.form-select,.form-textarea{width:100%;border:1px solid var(--border);border-radius:3px;
  padding:8px 11px;font-size:13px;font-family:'Inter',sans-serif;outline:none;
  transition:border-color 0.15s;color:var(--ink)}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--navy)}
.form-textarea{resize:vertical;min-height:80px}
.alert-box{padding:10px 14px;border-radius:3px;margin-bottom:14px;font-size:12px}
.alert-success{background:#DCFCE7;border:1px solid #86EFAC;color:#166534}
.alert-error{background:#FEE2E2;border:1px solid #FECACA;color:#DC2626}
</style>
<%- style || '' %>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark"><span>P</span></div>
    <div class="logo-text">
      <span class="logo-name">Praeto</span>
      <span class="logo-sub">Admin Panel</span>
    </div>
    <div class="admin-badge">ADMIN</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">Management</div>
    <a href="/admin" class="nav-link <%= locals.adminPage === 'dashboard' ? 'active' : '' %>">⬡ Dashboard</a>
    <a href="/admin/members" class="nav-link <%= locals.adminPage === 'members' ? 'active' : '' %>">◎ Members</a>
    <a href="/admin/alerts" class="nav-link <%= locals.adminPage === 'alerts' ? 'active' : '' %>">⚠ Compliance Alerts</a>
    <a href="/admin/broadcast" class="nav-link <%= locals.adminPage === 'broadcast' ? 'active' : '' %>">✉ Broadcast Emails</a>
    <div class="nav-section">Portal</div>
    <a href="/portal" class="nav-link">← Member Portal</a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <%= locals.member ? member.full_name : '' %><br>
      <span style="color:var(--gold);font-family:'JetBrains Mono',monospace;font-size:9px">ADMINISTRATOR</span>
    </div>
    <a href="#" onclick="logout()" class="sidebar-logout">Sign Out</a>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div class="topbar-title"><%- locals.pageTitle || title || 'Admin' %></div>
    <div style="display:flex;gap:10px;align-items:center">
      <span style="font-size:11px;color:var(--muted)">FSP 1457</span>
      <a href="/admin/alerts" class="btn btn-primary btn-sm">+ New Alert</a>
    </div>
  </div>
  <div class="content">
    <%- body %>
  </div>
</div>

<script>
async function logout(reason) {
  try { await fetch('/api/auth/logout', { method: 'POST' }); } catch (e) {}
  window.location.href = reason === 'idle' ? '/portal/login?timeout=1' : '/portal/login';
}

// ─── Idle timeout: log out after 15 minutes of no activity ──────────────────
// Keep IDLE_TIMEOUT_MS in sync with jwt.expiresIn in src/config.js.
(function () {
  var IDLE_TIMEOUT_MS = 15 * 60 * 1000;   // 15 minutes
  var KEEPALIVE_MS    = 5 * 60 * 1000;
  var idleTimer, lastPing = Date.now();

  function resetIdle() {
    clearTimeout(idleTimer);
    idleTimer = setTimeout(function () { logout('idle'); }, IDLE_TIMEOUT_MS);
    if (Date.now() - lastPing > KEEPALIVE_MS) {
      lastPing = Date.now();
      fetch('/api/auth/me', { method: 'GET' }).catch(function () {});
    }
  }

  ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click']
    .forEach(function (evt) { window.addEventListener(evt, resetIdle, { passive: true }); });

  resetIdle();
})();

async function updateMemberStatus(id, status) {
  if (!confirm('Change member status to: ' + status + '?')) return;
  const res = await fetch('/admin/members/' + id + '/status', {
    method: 'POST', headers: {'Content-Type':'application/json'}, credentials:'include',
    body: JSON.stringify({ status })
  });
  if (res.ok) location.reload();
  else alert('Failed to update status.');
}

async function updateMemberTier(id, tier) {
  const res = await fetch('/admin/members/' + id + '/tier', {
    method: 'POST', headers: {'Content-Type':'application/json'}, credentials:'include',
    body: JSON.stringify({ tier })
  });
  if (res.ok) location.reload();
  else alert('Failed to update tier.');
}
</script>
<%- script || '' %>
</body>
</html>
