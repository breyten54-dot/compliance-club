<% locals.activePage = 'ai' %>

<style>
.chat-wrap{display:grid;grid-template-columns:220px 1fr;gap:16px;height:calc(100vh - 140px)}
.conv-list{display:flex;flex-direction:column;gap:4px;overflow-y:auto}
.conv-item{padding:9px 12px;border-radius:3px;cursor:pointer;font-size:12px;color:var(--muted);
  border:1px solid transparent;transition:all 0.15s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.conv-item:hover{border-color:var(--border);color:var(--ink)}
.conv-item.active{background:rgba(201,168,76,0.08);border-color:rgba(201,168,76,0.3);color:var(--navy);font-weight:600}
.chat-main{display:flex;flex-direction:column;background:white;border:1px solid var(--border);border-radius:4px;overflow:hidden}
.messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.msg{display:flex;gap:12px;align-items:flex-start;max-width:85%}
.msg.user{align-self:flex-end;flex-direction:row-reverse}
.msg-bubble{padding:12px 16px;border-radius:6px;font-size:14px;line-height:1.7}
.msg.user .msg-bubble{background:var(--navy);color:white;border-radius:6px 6px 2px 6px}
.msg.assistant .msg-bubble{background:var(--surface);border:1px solid var(--border);color:var(--ink);border-radius:6px 6px 6px 2px}
.msg-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;flex-shrink:0}
.msg.user .msg-avatar{background:var(--gold);color:var(--navy)}
.msg.assistant .msg-avatar{background:var(--navy);color:var(--gold)}
.chat-input-row{padding:16px;border-top:1px solid var(--border);display:flex;gap:10px}
.chat-input{flex:1;border:1px solid var(--border);border-radius:3px;padding:10px 14px;
  font-size:14px;font-family:'Inter',sans-serif;outline:none;resize:none;min-height:42px;max-height:120px}
.chat-input:focus{border-color:var(--navy)}
.typing-indicator{display:none;padding:12px 16px;background:var(--surface);border:1px solid var(--border);
  border-radius:6px;font-size:13px;color:var(--muted)}
.typing-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--muted);
  margin:0 2px;animation:blink 1.4s infinite}
.typing-dot:nth-child(2){animation-delay:0.2s}
.typing-dot:nth-child(3){animation-delay:0.4s}
@keyframes blink{0%,80%,100%{opacity:0}40%{opacity:1}}
.quick-btn{padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:16px;
  font-size:12px;cursor:pointer;color:var(--muted);font-family:'Inter',sans-serif;transition:all 0.15s}
.quick-btn:hover{border-color:var(--navy);color:var(--navy)}
@media(max-width:768px){.chat-wrap{grid-template-columns:1fr;height:auto}.conv-list{display:none}}
</style>

<div class="chat-wrap">
  <!-- Conversation history sidebar -->
  <div>
    <button onclick="newConversation()" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;margin-bottom:12px">
      + New Conversation
    </button>
    <div class="conv-list" id="convList">
      <% conversations.forEach(c => { %>
      <div class="conv-item <%= activeConvId === c.id ? 'active' : '' %>"
           onclick="loadConversation('<%= c.id %>')" id="conv-<%= c.id %>">
        <%= c.first_message ? c.first_message.substring(0, 50) + (c.first_message.length > 50 ? '…' : '') : 'New conversation' %>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Chat area -->
  <div class="chat-main">
    <!-- Header -->
    <div style="padding:14px 20px;border-bottom:1px solid var(--border);
      display:flex;align-items:center;gap:12px">
      <div style="width:36px;height:36px;background:var(--navy);border-radius:50%;
        display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--gold)">◈</div>
      <div>
        <div style="font-weight:700;color:var(--navy);font-size:14px">AI Compliance Advisor</div>
        <div style="font-size:11px;color:var(--muted)">Powered by Claude · South African FSP compliance specialist</div>
      </div>
      <div style="margin-left:auto">
        <span style="width:8px;height:8px;border-radius:50%;background:#22C55E;display:inline-block"></span>
        <span style="font-size:11px;color:var(--muted);margin-left:4px">Online</span>
      </div>
    </div>

    <!-- Messages -->
    <div class="messages" id="messages">
      <!-- Welcome message -->
      <div class="msg assistant">
        <div class="msg-avatar">P</div>
        <div>
          <div class="msg-bubble">
            <strong>Welcome to the Praeto AI Compliance Advisor.</strong><br><br>
            I'm your expert guide to South African financial services compliance — covering FAIS, FIC Act,
            PPR, FSCA requirements, CPD obligations, RE1/RE5 preparation, and more.<br><br>
            Ask me anything about your compliance obligations, template usage, or regulatory changes.
          </div>
          <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap">
            <button class="quick-btn" onclick="quickAsk('What AML/CFT programme updates are required for 2026?')">AML/CFT 2026 updates</button>
            <button class="quick-btn" onclick="quickAsk('Explain the PPR Section 8 replacement disclosure changes')">PPR Section 8 changes</button>
            <button class="quick-btn" onclick="quickAsk('What are the RE5 scenario question format changes for 2026?')">RE5 format changes</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Typing indicator -->
    <div id="typingRow" style="padding:0 20px 12px;display:none">
      <div class="msg assistant">
        <div class="msg-avatar">P</div>
        <div class="typing-indicator" style="display:block">
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="chat-input-row">
      <textarea class="chat-input" id="chatInput" placeholder="Ask about FAIS, FIC Act, CPD requirements, FSCA regulations…"
        rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button class="btn btn-primary" onclick="sendMessage()" id="sendBtn" style="flex-shrink:0">Send →</button>
    </div>
    <div style="padding:8px 16px 12px;font-size:11px;color:var(--muted);line-height:1.5;border-top:1px solid var(--border,#E5E0D5)">
      <strong>Not financial or legal advice.</strong> The Compliance Advisor provides general regulatory
      information for educational purposes only and does not constitute advice under the FAIS Act.
      Always verify against the current legislation and consult a qualified compliance officer or attorney
      for specific matters. See our <a href="/terms.html" target="_blank" style="color:var(--navy,#1F3864)">Terms</a>.
    </div>
  </div>
</div>

<script>
let currentConvId = '<%= activeConvId || "" %>';

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function quickAsk(text) {
  document.getElementById('chatInput').value = text;
  sendMessage();
}

async function sendMessage() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  const btn = document.getElementById('sendBtn');
  btn.disabled = true;
  input.value = '';
  input.style.height = 'auto';

  appendMessage('user', msg);
  document.getElementById('typingRow').style.display = 'block';
  scrollToBottom();

  try {
    const res = await fetch('/api/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ message: msg, conversation_id: currentConvId || undefined }),
    });
    const data = await res.json();

    document.getElementById('typingRow').style.display = 'none';

    if (!res.ok) {
      appendMessage('assistant', data.error || 'Sorry, I encountered an error. Please try again.');
    } else {
      currentConvId = data.conversation_id;
      appendMessage('assistant', data.reply);
    }
  } catch {
    document.getElementById('typingRow').style.display = 'none';
    appendMessage('assistant', 'Network error. Please check your connection and try again.');
  }

  btn.disabled = false;
  scrollToBottom();
}

function appendMessage(role, text) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  const avatar = role === 'user' ? '<%= member.full_name.charAt(0).toUpperCase() %>' : 'P';
  // Convert markdown-ish newlines
  const formatted = text.replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  div.innerHTML = `<div class="msg-avatar">${avatar}</div><div class="msg-bubble">${formatted}</div>`;
  msgs.appendChild(div);
}

function scrollToBottom() {
  const msgs = document.getElementById('messages');
  msgs.scrollTop = msgs.scrollHeight;
}

async function loadConversation(id) {
  try {
    const res = await fetch('/api/ai/conversations/' + id, { credentials: 'include' });
    if (!res.ok) return;
    const data = await res.json();
    currentConvId = id;

    // Clear messages
    const msgs = document.getElementById('messages');
    msgs.innerHTML = '';

    // Render history
    data.messages.forEach(m => appendMessage(m.role, m.content));
    scrollToBottom();

    // Update active conv
    document.querySelectorAll('.conv-item').forEach(el => el.classList.remove('active'));
    const el = document.getElementById('conv-' + id);
    if (el) el.classList.add('active');
  } catch {}
}

function newConversation() {
  currentConvId = '';
  const msgs = document.getElementById('messages');
  msgs.innerHTML = '';
  appendMessage('assistant', 'Starting a new conversation. What compliance question can I help you with?');
  document.querySelectorAll('.conv-item').forEach(el => el.classList.remove('active'));
}
</script>
