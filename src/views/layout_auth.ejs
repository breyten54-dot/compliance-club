<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%- title || 'Praeto Compliance Club' %></title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#1F3864;--navy-d:#162952;--gold:#C9A84C;--gold-l:#E8C96A;
  --ink:#111827;--muted:#6B7280;--border:#E5E0D5;--surface:#F9F8F5}
body{font-family:'Inter',sans-serif;background:linear-gradient(150deg,var(--navy-d),var(--navy));
  min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;
  -webkit-font-smoothing:antialiased}
.auth-card{background:white;border-radius:6px;width:460px;max-width:100%;box-shadow:0 24px 64px rgba(0,0,0,0.35)}
.auth-header{background:var(--navy);padding:28px 32px;border-radius:6px 6px 0 0;border-bottom:3px solid var(--gold)}
.auth-logo-mark{width:38px;height:38px;background:var(--gold);border-radius:2px;display:inline-flex;
  align-items:center;justify-content:center;vertical-align:middle;margin-right:10px}
.auth-logo-mark span{font-family:'Playfair Display',serif;color:var(--navy);font-size:17px;font-weight:900}
.auth-brand{display:inline-block;vertical-align:middle}
.auth-brand-name{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;color:white;line-height:1.2;display:block}
.auth-brand-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--gold);letter-spacing:0.15em;text-transform:uppercase}
.auth-body{padding:32px}
.auth-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--navy);margin-bottom:6px}
.auth-sub{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:12px;font-weight:600;color:var(--ink);margin-bottom:5px}
.form-input,.form-select{width:100%;border:1px solid var(--border);border-radius:3px;
  padding:10px 12px;font-size:14px;font-family:'Inter',sans-serif;outline:none;
  transition:border-color 0.15s;color:var(--ink)}
.form-input:focus,.form-select:focus{border-color:var(--navy)}
.btn-submit{width:100%;background:var(--gold);color:var(--navy);border:none;padding:13px;
  border-radius:3px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;
  transition:background 0.15s;letter-spacing:0.01em}
.btn-submit:hover{background:var(--gold-l)}
.btn-submit:disabled{opacity:0.6;cursor:not-allowed}
.auth-footer{text-align:center;margin-top:20px;font-size:13px;color:var(--muted)}
.auth-footer a{color:var(--navy);font-weight:600;text-decoration:none}
.auth-footer a:hover{text-decoration:underline}
.error-box{background:#FEE2E2;border:1px solid #FECACA;color:#DC2626;
  padding:10px 14px;border-radius:3px;font-size:13px;margin-bottom:16px}
.success-box{background:#DCFCE7;border:1px solid #86EFAC;color:#166534;
  padding:10px 14px;border-radius:3px;font-size:13px;margin-bottom:16px}
.form-hint{font-size:11px;color:var(--muted);margin-top:3px}
.divider{border:none;border-top:1px solid var(--border);margin:20px 0}
</style>
</head>
<body>
<div class="auth-card">
  <div class="auth-header">
    <div class="auth-logo-mark"><span>P</span></div>
    <div class="auth-brand">
      <span class="auth-brand-name">Praeto Compliance Club</span>
      <span class="auth-brand-sub">FSP 1457 · Member Portal</span>
    </div>
  </div>
  <div class="auth-body">
    <%- body %>
  </div>
</div>
<%- script || '' %>
</body>
</html>
