<h2 class="auth-title">Reset Password</h2>
<p class="auth-sub">Enter your email and we'll send you a reset link.</p>

<div id="errorBox" class="error-box" style="display:none"></div>
<div id="successBox" class="success-box" style="display:none">
  Reset link sent. Check your email (including spam folder).
</div>

<div id="formSection">
  <div class="form-group">
    <label class="form-label">Email Address</label>
    <input type="email" class="form-input" id="email" placeholder="thabo@yourfsp.co.za">
  </div>
  <button class="btn-submit" id="btn" onclick="doReset()">Send Reset Link →</button>
</div>

<div class="auth-footer" style="margin-top:20px">
  <a href="/portal/login">← Back to login</a>
</div>

<script>
async function doReset() {
  const email = document.getElementById('email').value.trim();
  const btn = document.getElementById('btn');
  if (!email) return;
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    await fetch('/api/auth/forgot-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
    });
    document.getElementById('formSection').style.display = 'none';
    document.getElementById('successBox').style.display = 'block';
  } catch {
    document.getElementById('errorBox').textContent = 'Error. Please try again.';
    document.getElementById('errorBox').style.display = 'block';
    btn.disabled = false; btn.textContent = 'Send Reset Link →';
  }
}
</script>
