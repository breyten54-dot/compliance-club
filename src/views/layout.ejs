<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%- title || 'Praeto Compliance Club' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1F3864;--navy-d:#162952;--navy-l:#2E4F8A;
  --gold:#C9A84C;--gold-l:#E8C96A;--gold-pale:#F7EDD0;
  --ink:#111827;--muted:#6B7280;--subtle:#9CA3AF;
  --surface:#F9F8F5;--border:#E5E0D5;--white:#fff;
  --red:#EF4444;--green:#22C55E;--yellow:#F59E0B;
  --sidebar:240px;
}
body{font-family:'Inter',sans-serif;background:var(--surface);color:var(--ink);
  display:flex;min-height:100vh;font-size:15px;-webkit-font-smoothing:antialiased}
.playfair{font-family:'Playfair Display',serif}
.mono{font-family:'JetBrains Mono',monospace}

/* SIDEBAR */
.sidebar{width:var(--sidebar);background:var(--navy-d);flex-shrink:0;
  display:flex;flex-direction:column;position:fixed;top:0;bottom:0;left:0;z-index:50;
  border-right:1px solid rgba(201,168,76,0.15)}
.sidebar-logo{padding:24px 20px;border-bottom:1px solid rgba(255,255,255,0.07)}
.sidebar-logo-mark{width:36px;height:36px;background:var(--gold);border-radius:2px;
  display:inline-flex;align-items:center;justify-content:center;margin-right:10px;vertical-align:middle}
.sidebar-logo-mark span{font-family:'Playfair Display',serif;color:var(--navy);font-size:16px;font-weight:900}
.sidebar-brand-name{font-family:'Playfair Display',serif;font-size:13px;font-weight:700;color:white;line-height:1.2;vertical-align:middle}
.sidebar-brand-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--gold);
  letter-spacing:0.15em;text-transform:uppercase;display:block;margin-top:2px}
.sidebar-nav{flex:1;padding:16px 0;overflow-y:auto}
.nav-group{padding:0 12px;margin-bottom:8px}
.nav-group-label{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,0.3);
  letter-spacing:0.15em;text-transform:uppercase;padding:12px 8px 6px}
.nav-link{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:3px;
  font-size:13px;font-weight:500;color:rgba(255,255,255,0.6);text-decoration:none;transition:all 0.15s}
.nav-link:hover{background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.9)}
.nav-link.active{background:rgba(201,168,76,0.12);color:var(--gold)}
.nav-link .icon{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.sidebar-footer{padding:16px;border-top:1px solid rgba(255,255,255,0.07)}
.sidebar-member{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:3px;
  background:rgba(255,255,255,0.04)}
.sidebar-member-avatar{width:32px;height:32px;background:var(--gold);border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;
  font-size:13px;font-weight:700;color:var(--navy);flex-shrink:0}
.sidebar-member-name{font-size:12px;font-weight:600;color:rgba(255,255,255,0.9);line-height:1.2}
.sidebar-member-tier{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--gold);
  text-transform:uppercase;letter-spacing:0.08em}
.sidebar-logout{display:block;margin-top:8px;padding:7px 12px;border-radius:3px;
  font-size:12px;color:rgba(255,255,255,0.4);text-decoration:none;text-align:center;
  border:1px solid rgba(255,255,255,0.1);transition:all 0.15s}
.sidebar-logout:hover{background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.7)}

/* MAIN CONTENT */
.main{margin-left:var(--sidebar);flex:1;min-width:0;display:flex;flex-direction:column}
.topbar{background:white;border-bottom:1px solid var(--border);padding:0 32px;height:60px;
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:40}
.topbar-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--navy)}
.topbar-actions{display:flex;gap:10px;align-items:center}
.content{flex:1;padding:32px}

/* CARDS */
.card{background:white;border:1px solid var(--border);border-radius:4px}
.card-header{padding:20px 24px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between}
.card-title{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:var(--navy)}
.card-body{padding:24px}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:28px}
.stat-card{background:white;border:1px solid var(--border);border-radius:4px;padding:20px 24px}
.stat-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.stat-value{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;color:var(--navy);line-height:1}
.stat-sub{font-size:12px;color:var(--muted);margin-top:4px}
.stat-card.gold .stat-value{color:var(--gold)}
.stat-card.green .stat-value{color:#16A34A}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:3px;
  font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;border:none;
  font-family:'Inter',sans-serif;transition:all 0.15s;letter-spacing:0.01em}
.btn-primary{background:var(--gold);color:var(--navy)}
.btn-primary:hover{background:var(--gold-l)}
.btn-navy{background:var(--navy);color:white}
.btn-navy:hover{background:var(--navy-d)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--ink)}
.btn-outline:hover{border-color:var(--navy);color:var(--navy)}
.btn-danger{background:#FEE2E2;color:#DC2626;border:1px solid #FECACA}
.btn-danger:hover{background:#FECACA}
.btn-sm{padding:6px 12px;font-size:12px}

/* BADGES */
.badge{display:inline-block;padding:2px 8px;border-radius:2px;font-size:11px;font-weight:700;
  font-family:'JetBrains Mono',monospace;letter-spacing:0.06em;text-transform:uppercase}
.badge-foundation{background:#EFF4FF;color:var(--navy)}
.badge-practitioner{background:#F0FDF4;color:#166534}
.badge-elite{background:rgba(201,168,76,0.15);color:#92400E}
.badge-active{background:#DCFCE7;color:#166534}
.badge-pending{background:#FEF3C7;color:#92400E}
.badge-suspended{background:#FEE2E2;color:#DC2626}
.badge-cancelled{background:#F3F4F6;color:#6B7280}
.badge-critical{background:#FEE2E2;color:#DC2626}
.badge-warning{background:#FEF3C7;color:#92400E}
.badge-info{background:#DBEAFE;color:#1E40AF}

/* TABLE */
.table-wrap{overflow-x:auto}
table.data-table{width:100%;border-collapse:collapse}
.data-table th{background:var(--surface);font-family:'JetBrains Mono',monospace;font-size:10px;
  font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);
  padding:10px 16px;text-align:left;border-bottom:2px solid var(--border)}
.data-table td{padding:12px 16px;border-bottom:1px solid var(--border);font-size:13px;color:var(--ink)}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:var(--surface)}

/* FORMS */
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:12px;font-weight:600;color:var(--ink);margin-bottom:5px;letter-spacing:0.01em}
.form-input,.form-select,.form-textarea{width:100%;border:1px solid var(--border);border-radius:3px;
  padding:9px 12px;font-size:14px;font-family:'Inter',sans-serif;outline:none;
  transition:border-color 0.15s;color:var(--ink);background:white}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--navy)}
.form-textarea{resize:vertical;min-height:100px}
.form-hint{font-size:11px;color:var(--muted);margin-top:4px}

/* ALERTS */
.alert-box{padding:12px 16px;border-radius:3px;margin-bottom:16px;font-size:13px;line-height:1.6}
.alert-success{background:#DCFCE7;border:1px solid #86EFAC;color:#166534}
.alert-error{background:#FEE2E2;border:1px solid #FECACA;color:#DC2626}
.alert-warn{background:#FEF3C7;border:1px solid #FCD34D;color:#92400E}
.alert-info{background:#DBEAFE;border:1px solid #93C5FD;color:#1E40AF}

/* PROGRESS BAR */
.progress-bar{height:8px;background:#E5E0D5;border-radius:4px;overflow:hidden;margin:8px 0}
.progress-fill{height:100%;border-radius:4px;background:var(--gold);transition:width 0.6s ease}
.progress-fill.green{background:#22C55E}
.progress-fill.red{background:var(--red)}

/* TIER TAG */
.tier-tag{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;
  padding:3px 8px;border-radius:2px;text-transform:uppercase;letter-spacing:0.08em}

/* MOBILE NAV TOGGLE */
.mobile-menu-btn{display:none;background:none;border:none;font-size:20px;cursor:pointer;color:var(--navy)}

@media(max-width:768px){
  .sidebar{transform:translateX(-100%);transition:transform 0.3s}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .content{padding:16px}
  .mobile-menu-btn{display:block}
  .stats-grid{grid-template-columns:1fr 1fr}
}
</style>
<%- style || '' %>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-mark"><span>P</span></div><a href="/portal" style="text-decoration:none;display:inline-block;vertical-align:middle">
    <span class="sidebar-brand-name">Praeto<br>Compliance Club<span class="sidebar-brand-sub">FSP 1457</span></span></a>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-group">
      <div class="nav-group-label">Member Portal</div>
      <a href="/portal" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
        <span class="icon">⬡</span> Dashboard
      </a>
      <a href="/portal/alerts" class="nav-link <%= locals.activePage === 'alerts' ? 'active' : '' %>">
        <span class="icon">⚠</span> Compliance Alerts
      </a>
      <a href="/portal/cpd" class="nav-link <%= locals.activePage === 'cpd' ? 'active' : '' %>">
        <span class="icon">◎</span> CPD Tracker
      </a>
      <a href="/portal/templates" class="nav-link <%= locals.activePage === 'templates' ? 'active' : '' %>">
        <span class="icon">▤</span> Template Library
      </a>
      <a href="/portal/ai-advisor" class="nav-link <%= locals.activePage === 'ai' ? 'active' : '' %>">
        <span class="icon">◈</span> AI Compliance Advisor
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-label">Account</div>
      <a href="/portal/subscribe" class="nav-link <%= locals.activePage === 'subscribe' ? 'active' : '' %>">
        <span class="icon">↑</span> Upgrade Membership
      </a>
      <a href="/portal/settings" class="nav-link <%= locals.activePage === 'settings' ? 'active' : '' %>">
        <span class="icon">⚙</span> Settings
      </a>
      <% if (locals.member && member.is_admin) { %>
      <a href="/admin" class="nav-link">
        <span class="icon">★</span> Admin Panel
      </a>
      <% } %>
    </div>
  </nav>

  <div class="sidebar-footer">
    <% if (locals.member) { %>
    <div class="sidebar-member">
      <div class="sidebar-member-avatar"><%= member.full_name.charAt(0).toUpperCase() %></div>
      <div>
        <div class="sidebar-member-name"><%= member.full_name.split(' ')[0] %></div>
        <div class="sidebar-member-tier"><%= member.tier %></div>
      </div>
    </div>
    <% } %>
    <a href="#" class="sidebar-logout" onclick="logout()">Sign Out</a>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <!-- Topbar -->
  <div class="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button class="mobile-menu-btn" onclick="toggleSidebar()">☰</button>
      <div class="topbar-title"><%- locals.pageTitle || title || '' %></div>
    </div>
    <div class="topbar-actions">
      <% if (locals.member) { %>
      <span class="badge badge-<%= member.tier %>"><%= member.tier %></span>
      <span style="font-size:12px;color:var(--muted)"><%= member.status === 'active' ? '● Active' : '○ Pending' %></span>
      <% } %>
    </div>
  </div>

  <!-- Page content -->
  <div class="content">
    <%- body %>
  </div>
</div>

<script>
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}
async function logout() {
  await fetch('/api/auth/logout', { method: 'POST' });
  window.location.href = '/portal/login';
}
</script>
<%- script || '' %>
</body>
</html>
