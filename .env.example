# Praeto Compliance Club — environment template
# Copy to .env (local) or set in the Vercel project settings (production).
# NEVER commit real secrets. config.js accepts either FOO_BAR or FOOBAR spellings.

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public base URL of the deployed app (used in emails, PayFast return URLs).
# In prod Vercel provides VERCEL_PROJECT_PRODUCTION_URL automatically; set BASE_URL locally.
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Database (Postgres — shared Supabase in prod; session pooler) ────────────
# postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/praeto

# ── Auth (JWT + session cookie) ──────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_random_characters
JWT_EXPIRES_IN=15m

# ── PayFast (memberships) ────────────────────────────────────────────────────
# PAYFAST_ENV=sandbox for testing, production for live.
PAYFAST_ENV=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# Tier prices (ZAR/month) + elite seat cap.
PRICE_FOUNDATION=299
PRICE_PRACTITIONER=799
PRICE_ELITE=2500
ELITE_MEMBER_CAP=50

# ── AI Compliance Advisor (optional — returns a friendly 503 until set) ──────
ANTHROPIC_API_KEY=

# ── Email (choose ONE provider; sends are console stubs until a key is set) ──
RESEND_API_KEY=
# SENDGRID_API_KEY=
EMAIL_FROM=noreply@praeto.co.za
EMAIL_FROM_NAME=Praeto Compliance Club
ADMIN_EMAIL=berkeley@praeto.co.za
